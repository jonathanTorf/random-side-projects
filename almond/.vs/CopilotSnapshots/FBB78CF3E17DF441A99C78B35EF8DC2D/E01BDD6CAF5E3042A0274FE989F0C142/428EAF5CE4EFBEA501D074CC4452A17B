        void calcPen(int ci, int cj)
        {
            float theta0 = (ci - size / 2) * c;
            float theta1 = (cj - size / 2) * c;

            float omega0 = 0;
            float omega1 = 0;

            float v0 = 0;
            float v1 = 0;

            int j = 0;

            float localSubStep = subStep;
            for (double i = 0; i < simulationTime; i += timeStep)
            {
                for (int k = 0; k < 10; k++)
                {
                    float cash = theta0 - theta1;
                    float cashSin = MathF.Sin(cash);
                    float cashCos = MathF.Cos(cash);

                    float bottom = l1 * (2 * m0 + m1 - m1 * (float)Math.Cos(2 * theta0 - 2 * theta1));

                    float step0 = (-g * (2 * m0 + m1) * MathF.Sin(theta0));
                    float step1 = m1 * g * MathF.Sin(theta0 - 2 * theta1);
                    float step2 = 2 * cashSin * m1;
                    float step3 = v1 * v1 * l1 + v0 * v0 * l0 * cashCos;
                    float top0 = step0 - step1 - step2 * step3;

                    float step01 = 2 * cashSin;
                    float step21 = v0 * v0 * l0 * (m0 + m1);
                    float step31 = g * (m0 + m1) * MathF.Cos(theta0);
                    float step41 = v1 * v1 * l1 * m1 * cashCos;
                    float top1 = step01 * (step21 + step31 + step41);

                    omega0 += (top0 / bottom) * localSubStep;
                    omega1 += (top1 / bottom) * localSubStep;

                    theta0 += omega0 * localSubStep;
                    theta1 += omega1 * localSubStep;
                }
            }
            /*int r = 0;
            r = (int)((toDegrees(theta0) + 180) / 360 * 255);
            setPixel(ci, cj, Color.FromArgb(r, 0, 0));*/
            theta0list.Append(theta0);
        }

        void calcColor(float ang, int x, int y)
        {
            float cr = (MathF.Sin(ang) + 1f) * 0.5f;
            float cg = (MathF.Sin(ang + 2f * MathF.PI / 3f) + 1f) * 0.5f;
            float cb = (MathF.Sin(ang + 4f * MathF.PI / 3f) + 1f) * 0.5f;
            setPixel(x, y, Color.FromArgb((int)(cr * 255), (int)(cg * 255), (int)(cb * 255)));
        }
